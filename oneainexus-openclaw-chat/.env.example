# MySQL 数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=openclaw_chat

# Docker MySQL 配置（参考）
# MYSQL_USER=openclaw
# MYSQL_PASSWORD=openclaw123456

# 外部认证服务配置
NUXT_AUTH_API_URL=http://your-auth-server/api/user/info
NUXT_AUTH_TOKEN_HEADER=Authentication

# 注意：OpenClaw Gateway 将通过 Channel 插件 + SDK 主动连接本应用
# 本应用不需要配置 Gateway 地址，而是被动接收连接
